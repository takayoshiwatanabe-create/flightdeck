{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "next-intl": [
        "./node_modules/next-intl/dist/src/index.d.ts"
      ],
      "next-intl/server": [
        "./node_modules/next-intl/dist/src/server/index.d.ts"
      ],
      "next-intl/client": [
        "./node_modules/next-intl/dist/src/client/index.d.ts"
      ]
    },
    "jsx": "react-jsx",
    "baseUrl": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "es2022"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "next-env.d.ts",
    "**/*.js",
    "**/*.jsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "i18n/**/*.ts",
    "i18n/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "jest.setup.js",
    "vitest.setup.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

